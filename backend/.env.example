# Docker default: postgres:postgres@localhost:5432/diet_recommendation_db
# Manual install: postgresql://postgres:YOUR_PASSWORD@localhost:5432/diet_recommendation_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diet_recommendation_db
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
OPENAI_API_KEY=your-openai-api-key
DEBUG=True
# Comma-separated list for production, e.g. https://your-app.com,http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000
